# Gmail Email Scraper - Environment Variables
# Usage:
#   cp .env.example .env
#   Edit .env and fill in your credentials
#   source .env && python gmail_scraper.py

# Gmail account (full email address)
export GMAIL_USER=""

# Gmail App Password (NOT your Gmail login password)
# Must be generated in your Google Account security settings:
# https://myaccount.google.com/apppasswords
# Prerequisite: 2-Step Verification must be enabled.
export GMAIL_PASSWORD=""

# OpenRouter API key
# Get yours at: https://openrouter.ai/keys
export OPENROUTER_API_KEY=""
